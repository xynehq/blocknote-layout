{
  "name": "blocknote-layout",
  "description": "Layout and utility extensions for BlockNote editor - code runner, slideshow, whiteboard, genius, and mentions blocks",
  "keywords": [
    "blocknote",
    "editor",
    "layout",
    "code-runner",
    "python",
    "slideshow",
    "presentation",
    "revealjs",
    "whiteboard",
    "drawing",
    "canvas",
    "diagram",
    "react"
  ],
  "version": "3.1.1",
  "license": "MIT",
  "author": "Yash Gupta",
  "contributors": [
    "Yash Gupta <https://github.com/gyash1512>",
    "Harshpreet Singh <https://github.com/harshpreet931>",
    "Satvik Batra <https://github.com/satvikbatra>"
  ],
  "homepage": "https://github.com/xynehq/blocknote-layout#readme",
  "bugs": {
    "url": "https://github.com/xynehq/blocknote-layout/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xynehq/blocknote-layout.git",
    "directory": "packages/blocknote-layout"
  },
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./coderunner": {
      "types": "./dist/coderunner.d.ts",
      "import": "./dist/coderunner.js"
    },
    "./slideshow": {
      "types": "./dist/slideshow.d.ts",
      "import": "./dist/slideshow.js"
    },
    "./whiteboard": {
      "types": "./dist/whiteboard.d.ts",
      "import": "./dist/whiteboard.js"
    },
    "./genius": {
      "types": "./dist/genius.d.ts",
      "import": "./dist/genius.js"
    },
    "./mentions": {
      "types": "./dist/mentions.d.ts",
      "import": "./dist/mentions.js"
    },
    "./mentions/server": {
      "types": "./dist/mentions-server.d.ts",
      "import": "./dist/mentions-server.js"
    },
    "./whiteboard/server": {
      "types": "./dist/whiteboard-server.d.ts",
      "import": "./dist/whiteboard-server.js"
    },
    "./genius/server": {
      "types": "./dist/genius-server.d.ts",
      "import": "./dist/genius-server.js"
    },
    "./coderunner/server": {
      "types": "./dist/coderunner-server.d.ts",
      "import": "./dist/coderunner-server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig-build.json"
  },
  "dependencies": {
    "blocknote-layout-core": "workspace:^",
    "blocknote-layout-coderunner": "workspace:^",
    "blocknote-layout-genius": "workspace:^",
    "blocknote-layout-mentions": "workspace:^",
    "blocknote-layout-slideshow": "workspace:^",
    "blocknote-layout-whiteboard": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  }
}

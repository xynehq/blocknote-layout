{
  "name": "blocknote-layout-coderunner",
  "description": "Code runner block for BlockNote with multi-language execution (Judge0 or custom handlers) and CodeMirror editing",
  "keywords": [
    "blocknote",
    "editor",
    "code-runner",
    "codemirror",
    "judge0",
    "react"
  ],
  "version": "3.0.0",
  "license": "MIT",
  "author": "Yash Gupta",
  "contributors": [
    "Yash Gupta <https://github.com/gyash1512>",
    "Harshpreet Singh <https://github.com/harshpreet931>",
    "Satvik Batra <https://github.com/satvikbatra>"
  ],
  "homepage": "https://github.com/xynehq/blocknote-layout#readme",
  "bugs": {
    "url": "https://github.com/xynehq/blocknote-layout/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xynehq/blocknote-layout.git",
    "directory": "packages/coderunner"
  },
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig-build.json && vite build"
  },
  "peerDependencies": {
    "@blocknote/core": "0.51.4",
    "@blocknote/react": "0.51.4",
    "@uiw/react-codemirror": "^4.21.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-icons": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/state": "^6.5.2"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vite": "^5.1.7",
    "@vitejs/plugin-react": "^4.2.1",
    "vite-plugin-dts": "^3.7.3",
    "vite-plugin-lib-inject-css": "^2.0.0",
    "glob": "^10.3.10",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "@blocknote/core": "0.51.4",
    "@blocknote/react": "0.51.4",
    "@uiw/react-codemirror": "^4.21.0"
  }
